PORT=5000
# MongoDB Atlas URI (no placeholders in production):
MONGODB_URI=mongodb+srv://USER:ENCODED_PASSWORD@cluster0.xxxxx.mongodb.net/ipl_auction?retryWrites=true&w=majority
# Comma-separated allowed frontend origins
FRONTEND_URL=https://your-frontend.vercel.app
# Allow all Vercel preview URLs (*.vercel.app) when true
ALLOW_VERCEL_PREVIEWS=true
ADMIN_KEY=ipl_admin_2024
NODE_ENV=development

# ── Live IPL teams integration ─────────────────────────────────────────
# URL that returns IPL 2026 squads. Point this to your chosen provider:
# - RapidAPI Cricbuzz IPL squads endpoint
# - ESPN Cricinfo league squads endpoint
# Response should be normalised in services/iplTeamsService.js
IPL_SQUADS_URL=https://your-ipl-provider.example.com/ipl-2026-squads

# If using RapidAPI, set these (optional for non-RapidAPI sources)
RAPIDAPI_IPL_HOST=cricbuzz-cricket.p.rapidapi.com
RAPIDAPI_IPL_KEY=your_rapidapi_key_here

# Cache TTL for squad data in ms (default: 24h)
IPL_SQUADS_TTL_MS=86400000
